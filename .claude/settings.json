{
  "model": "haiku",
  "hooks": {
    "PreCommit": [
      {
        "type": "command",
        "command": "hooks/code-format-check.sh"
      },
      {
        "type": "command",
        "command": "hooks/test-hook.sh"
      },
      {
        "type": "command",
        "command": "hooks/test-runner-pre-commit.py"
      }
    ],
    "UserPromptSubmit": [
      {
        "type": "command",
        "command": "hooks/promptshield-check.sh"
      }
    ]
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "playwright@claude-plugins-official": true
  }
}