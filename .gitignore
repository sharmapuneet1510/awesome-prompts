*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
env/
ENV/
env.bak/
venv.bak/

# IDE-specific files (user preferences, not repo standards)
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Local environment variables (secrets, credentials)
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local

# IDE settings (personal, not shared)
.claude/settings.local.json  # Personal user settings, not committed
.vscode/settings.json
.vscode/launch.json
.idea/**/*.xml

# Temporary files
*.tmp
*.bak
*.log
*.pid

# OS-specific
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db

# Node modules (if used)
node_modules/
npm-debug.log
yarn-error.log

# Coverage reports (generated)
htmlcov/
.coverage
.coverage.*
.cache
.pytest_cache/
coverage.xml

# SonarQube reports
.sonarqube/
.sonar/

# Git-specific
.git/
.gitkeep

# ═══════════════════════════════════════════════════════════════════════════════
# CRITICAL: Generated IDE/Platform Config Files (Auto-Exported by tools/exporter.py)
# ═══════════════════════════════════════════════════════════════════════════════
# These directories contain auto-generated skill and agent files for different IDEs.
# They are generated by tools/exporter.py and should NEVER be committed to git.
# Users should run: python tools/exporter.py to regenerate after pulling changes.
# If accidentally committed, remove with: git rm --cached -r <directory>

# GitHub/Copilot Integration (Copilot CLI & GitHub Copilot Chat)
.github/instructions/
.github/agents/
.github/copilot/

# Claude Code / Claude IDE Integration
# NOTE: .claude/ is TRACKED and committed (not ignored)
# Only .claude/settings.local.json is ignored (personal settings)

# Cursor IDE Integration
.cursor/
.cursor/rules/

# Windsurf IDE Integration
.windsurf/
.windsurf/rules/

# Google Gemini Integration
.gemini/
.gemini/skills/
.gemini/agents/

# Continue IDE Extension
.continue/prompts/
.continue/skills/
.continue/agents/

# Aider CLI Integration
.aider/
.aider/agents/
.aider/skills/
.aider/hooks/

# OpenAI Integration
tools/output/openai/
tools/output/openai/skills/
tools/output/openai/agents/

# Additional safeguards: catch any IDE config files not explicitly listed
# Prevent accidental commits of exporter output
*.mdc                          # Cursor markdown config files
.*/skills/                     # Catch skills in any hidden directory
.*/agents/                     # Catch agents in any hidden directory
.*/rules/                      # Catch rules in any hidden directory

# Generated context and feedback directories (local only)
.context/
.feedback/
context_builder/

# Superpowers: allow specs and plans (commit)
!docs/superpowers/specs/
!docs/superpowers/plans/
