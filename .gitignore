.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Local environment variables (secrets, credentials)
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local

# IDE settings (personal, not shared)
.claude/settings.local.json  # Personal user settings, not committed
.vscode/settings.json
.vscode/launch.json
.idea/**/*.xml

# Temporary files
*.tmp
*.bak
*.log
*.pid

# OS-specific
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db

# Node modules (if used)
node_modules/
