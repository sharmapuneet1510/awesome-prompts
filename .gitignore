# ═══════════════════════════════════════════════════════════════════════════════
# BUILD & PACKAGE (Python)
# ═══════════════════════════════════════════════════════════════════════════════
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
env/
ENV/
env.bak/
venv.bak/

# ═══════════════════════════════════════════════════════════════════════════════
# IDE & EDITOR (personal settings, not repo standards)
# ═══════════════════════════════════════════════════════════════════════════════
.idea/
.vscode/settings.json
.vscode/launch.json
.idea/**/*.xml
*.swp
*.swo
*~

# IDE personal configuration (not shared)
.claude/settings.local.json

# ═══════════════════════════════════════════════════════════════════════════════
# SECURITY (secrets, credentials, local config)
# ═══════════════════════════════════════════════════════════════════════════════
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local

# ═══════════════════════════════════════════════════════════════════════════════
# OS & SYSTEM FILES
# ═══════════════════════════════════════════════════════════════════════════════
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db

# Temporary files
*.tmp
*.bak
*.log
*.pid

# ═══════════════════════════════════════════════════════════════════════════════
# TESTING & COVERAGE
# ═══════════════════════════════════════════════════════════════════════════════
htmlcov/
.coverage
.coverage.*
.cache
.pytest_cache/
coverage.xml

# ═══════════════════════════════════════════════════════════════════════════════
# CODE QUALITY & ANALYSIS
# ═══════════════════════════════════════════════════════════════════════════════
.sonarqube/
.sonar/

# Node modules (if used)
node_modules/
npm-debug.log
yarn-error.log

# ═══════════════════════════════════════════════════════════════════════════════
# CRITICAL: Platform-Exported Files (AUTO-GENERATED by tools/exporter.py)
# ═══════════════════════════════════════════════════════════════════════════════
# These directories are auto-generated by running: python tools/exporter.py
# They should NEVER be committed to git.
# After pulling changes, users should run: python tools/exporter.py
# If accidentally committed, remove with: git rm --cached -r <directory>

# GitHub/Copilot (Copilot CLI & GitHub Copilot Chat)
.github/instructions/
.github/agents/
.github/copilot/

# Cursor IDE
.cursor/

# Windsurf IDE
.windsurf/

# Google Gemini
.gemini/

# Continue IDE Extension
.continue/

# Aider CLI
.aider/

# OpenAI Platform
tools/output/openai/

# Catch-all: prevent any IDE config with hidden dir + skills/agents/rules
*.mdc

# ═══════════════════════════════════════════════════════════════════════════════
# SPECIAL: .claude/ is TRACKED & COMMITTED (platform exports for Claude Code)
# ═══════════════════════════════════════════════════════════════════════════════
# REASON: .claude/ is the primary export target for Claude Code (checked into repo)
# REASON: Users need these exports checked in for Claude Code to use them
# REASON: Other platforms (.github/, .cursor/, .windsurf/, etc.) are auto-generated
#
# Only .claude/settings.local.json is ignored (user's personal settings)
# After pulling, regenerate all platform exports with: python tools/exporter.py

# ═══════════════════════════════════════════════════════════════════════════════
# GENERATED OUTPUT (LOCAL ONLY - Never commit)
# ═══════════════════════════════════════════════════════════════════════════════
# These are produced by running agents and tools, not part of source

# Context & knowledge graphs (generated by context_builder, graphify)
.context/
graphify-out/

# Feedback & analysis reports (generated by quality:review, feedback tools)
.feedback/
reviews/

# Cached analysis (generated by context_builder)
context_builder/

# ═══════════════════════════════════════════════════════════════════════════════
# DOCUMENTATION: Allow tracked content in docs/superpowers/
# ═══════════════════════════════════════════════════════════════════════════════
# Specs and plans are committed, outputs are not

!docs/superpowers/specs/
!docs/superpowers/plans/
.cursorrules          # Auto-generated Cursor IDE rules (run: python tools/exporter.py --target cursor)
